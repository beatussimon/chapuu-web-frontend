{
  "expo": {
    "name": "Chapuu",
    "slug": "chapuu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chapuu.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Chapuu needs your location to display nearby restaurants and ensure accurate delivery mapping to your doorstep."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      },
      "package": "com.chapuu.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "chapuu",
    "plugins": [
      "expo-router",
      "expo-status-bar"
    ]
  }
}
